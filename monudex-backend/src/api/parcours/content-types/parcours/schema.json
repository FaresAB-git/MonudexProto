{
  "kind": "collectionType",
  "collectionName": "parcourss",
  "info": {
    "singularName": "parcours",
    "pluralName": "parcourss",
    "displayName": "Parcours"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "image_url": {
      "type": "string"
    },
    "tags": {
      "type": "json"
    },
    "duration_min": {
      "type": "integer"
    },
    "distance_km": {
      "type": "decimal"
    },
    "is_published": {
      "type": "boolean",
      "default": false
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "parcours"
    },
    "parcours_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::parcours-item.parcours-item",
      "mappedBy": "parcour"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "parcours"
    },
    "user_parcours": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-parcours.user-parcours",
      "mappedBy": "parcours"
    }
  }
